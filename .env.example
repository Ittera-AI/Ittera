# ============================================================
# Iterra Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Database ----
DATABASE_URL=postgresql://iterra:iterra@localhost:5432/iterra

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Set true only if you want demo placeholder scheduled jobs enabled.
ENABLE_PLACEHOLDER_TASKS=false

# ---- Auth ----
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Supabase (backend JWT verification) ----
# URL: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# JWT secret: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
# Google Drive OAuth (separate from Google login — drive.file scope only)
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/v1/social/callback/google-drive
# LinkedIn scraper session cookie (alternative to username/password auth)
LINKEDIN_SESSION_COOKIE=
FRONTEND_URL=http://localhost:3000
WAITLIST_TOTAL_SEATS=100
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=
REPLY_TO_EMAIL=

# ---- AI ----
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Calendar: use iterra_ai CalendarEngine when true and Anthropic key is set; otherwise mock plan.
USE_ITERRA_AI_CALENDAR=false

# ---- App ----
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ---- Frontend (Next.js) ----
# Leave unset while running `next dev`: browser uses same-origin /api/v1 → Next rewrites to FastAPI (see API_PROXY_TARGET).
# Or set full URL for direct cross-origin calls, e.g. http://localhost:8000
NEXT_PUBLIC_API_URL=
# Rewrite target from Next.js server to FastAPI (Compose service name inside Docker network).
API_PROXY_TARGET=http://127.0.0.1:8000
