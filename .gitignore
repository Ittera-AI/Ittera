# ========================
# Iterra .gitignore
# ========================

# Environment
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Databases
*.db
*.sqlite
*.sqlite3

# Docker
.docker/

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Alembic (generated migration artifacts)
# Keep versions/ but ignore compiled .pyc inside
apps/api/app/db/migrations/versions/*.pyc

# Generated types (regenerate with make types)
# packages/shared-types/src/index.ts  # Uncomment if you want to gitignore generated types

# Celery
celerybeat-schedule
celerybeat.pid

# Secrets
*.pem
*.key
*.p12
